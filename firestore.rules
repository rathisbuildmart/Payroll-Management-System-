rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Catch-all security rule: deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Allow access specifically to our global shared payroll database document
    match /payroll_system_data/shared_db {
      allow read, write: if true;
    }
  }
}
